    {
      "parameters": {
        "promptType": "define",
        "text": "=Report content:\n{{ $json.output }}\n\nFormat this report as professional HTML for email.",
        "options": {
          "systemMessage": "You are an HTML formatting specialist. Take reports and format them as clean, professional HTML suitable for email.\n\nFormatting requirements:\n1. Create clean, professional HTML with proper structure\n2. Use appropriate heading tags (h1, h2, h3)\n3. Apply professional styling with inline CSS\n4. Use a readable font (Arial, Helvetica, or similar)\n5. Add proper spacing and margins\n6. Make links clickable\n7. Use a color scheme that's professional (blues, grays)\n8. Ensure mobile-friendly formatting\n9. Add a professional header with the report title\n10. Make it visually appealing but not cluttered\n\nReturn ONLY the complete HTML code, ready to be used as email body content. Include all necessary inline styles."
        }
      },
      "id": "b2bf533b-7b4e-487f-ac37-18755646d3c3",
