    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"findings\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"fact\": {\"type\": \"string\", \"description\": \"The factual finding\"},\n          \"source\": {\"type\": \"string\", \"description\": \"The source URL or publication\"},\n          \"date\": {\"type\": \"string\", \"description\": \"Publication or update date\"},\n          \"credibility\": {\"type\": \"string\", \"description\": \"Assessment of source credibility\"}\n        }\n      }\n    }\n  }\n}"
