    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"verified_facts\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"fact\": {\"type\": \"string\", \"description\": \"The verified fact\"},\n          \"status\": {\"type\": \"string\", \"enum\": [\"verified\", \"unverified\"], \"description\": \"Verification status\"},\n          \"sources\": {\n            \"type\": \"array\",\n            \"items\": {\"type\": \"string\"},\n            \"description\": \"List of independent sources confirming this fact\"\n          },\n          \"source_count\": {\"type\": \"number\", \"description\": \"Number of independent sources found\"},\n          \"confidence\": {\"type\": \"string\", \"description\": \"Confidence level in verification\"}\n        }\n      }\n    }\n  }\n}"
      },
      "id": "6b9e3bc5-ea86-433b-b1a9-04fc0e03372d",
      "name": "Fact Check Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        3488,
        768
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Research findings to verify:\n{{ $json.output.findings }}\n\nVerify each fact by finding at least 2 independent sources.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a fact-checking agent. Your task is to verify the research findings provided.\n\nVerification criteria:\n1. For each fact, search for AT LEAST 2 independent sources that confirm it\n2. Sources must be independent (different domains, different organizations)\n3. Only mark a fact as \"verified\" if you find 2+ independent sources\n4. If you find only 1 source or cannot confirm, mark as \"unverified\"\n5. List all source URLs you found for each fact\n6. Provide a confidence assessment\n\nBe thorough and rigorous. Use the search tool to find multiple sources for each claim. Cross-reference information across different credible sources.\n\nReturn only facts that meet the verification criteria (2+ independent sources) with status \"verified\"."
        }
      },
      "id": "55245de4-c796-4089-9f1a-d43ef5bd1e8e",
