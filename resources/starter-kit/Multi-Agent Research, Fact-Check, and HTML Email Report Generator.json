    {
      "parameters": {
        "promptType": "define",
        "text": "=Topic: {{ $('Workflow Configuration').item.json.topic }}\n\nVerified facts:\n{{ $json.output.verified_facts }}\n\nWrite a comprehensive report based on these verified facts.",
        "options": {
          "systemMessage": "You are a professional report writer. Create comprehensive, well-written reports based on verified facts.\n\nReport requirements:\n1. Write a clear, engaging report under 1,000 words\n2. Use only the verified facts provided\n3. Organize information logically with clear sections\n4. Include an executive summary at the beginning\n5. Use professional, accessible language\n6. Cite sources inline where appropriate\n7. End with key takeaways or conclusions\n\nStructure:\n- Executive Summary\n- Main Body (organized by themes or topics)\n- Key Takeaways\n- Sources\n\nWrite in a professional but readable style. Make the report informative and valuable."
        }
      },
      "id": "e4eb11aa-8b01-444a-9403-2404bca10068",
      "name": "Report Writing Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
